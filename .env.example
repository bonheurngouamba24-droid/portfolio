# Copie ce fichier en .env.local (dev) et renseigne les mêmes clés dans
# Vercel → Project Settings → Environment Variables (Production + Preview).
#
# Trouvables dans Supabase → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clé anonyme uniquement : les tables sont en lecture publique (RLS),
# aucune clé secrète n'est nécessaire côté site.
